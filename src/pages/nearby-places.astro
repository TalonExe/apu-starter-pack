---
import Layout from "../layouts/Layout.astro";

import nearby1 from "../assets/Stadium-Bukit-Jalil.png";
import nearby2 from "../assets/Sri-Petaling.png";
import nearby3 from "../assets/Pavilion-Bukit-Jalil.png";
import nearby4 from "../assets/Endah-Parade.png";

const nearbyPlaces = [
  {
    image: nearby1.src,
    caption: "Stadium Bukit Jalil",
  },
  {
    image: nearby2.src,
    caption: "Bandar Baru Sri Petaling",
  },
  {
    image: nearby3.src,
    caption: "Pavilion Bukit Jalil",
  },
  {
    image: nearby4.src,
    caption: "Endah Parade",
  },
];
---

<Layout title="Nearby Places">
  <section class="py-10">
    <div class="mb-10 text-center">
      <h1 class="text-4xl font-extrabold text-slate-800">
        Nearby Places
      </h1>

      <p class="mt-3 text-slate-600">
        Useful places around campus for food, errands, studying, and relaxing.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {nearbyPlaces.map((place) => (
        <figure class="overflow-hidden rounded-3xl bg-white shadow-md transition hover:-translate-y-1 hover:shadow-xl">
          <img
            src={place.image}
            alt={place.caption}
            class="h-72 w-full object-contain"
          />

          <figcaption class="p-5 text-center text-xl font-bold text-slate-800">
            {place.caption}
          </figcaption>
        </figure>
      ))}
    </div>
  </section>
</Layout>
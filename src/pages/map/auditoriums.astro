---
import Layout from "../../layouts/Layout.astro"


---

<Layout>
  <section class="py-10">
    <a href="/apu-starter-pack/map" class="text-green-600 hover:underline">
      ← Back to Map
    </a>

    <div class="mt-8 rounded-3xl bg-white p-8 shadow-md">
      <h1 class="text-4xl font-extrabold text-slate-800">
        Auditoriums
      </h1>

      <p class="mt-4 text-slate-600">
        This page can include auditorium locations, seating information, and
        directions for students.
      </p>

      <img
        src="/images/auditoriums.jpg"
        alt="Auditoriums"
        class="mt-8 h-96 w-full rounded-2xl object-cover"
      />
    </div>
  </section>
</Layout>
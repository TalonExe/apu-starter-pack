---
import Layout from "../../layouts/Layout.astro"

import auditorium from "../../assets/Auditoriums.png";
---

<Layout>
  <section class="py-10">
    <a href="/apu-starter-pack/map" class="text-green-600 hover:underline">
      ← Back to Map
    </a>

    <div class="mt-8 rounded-3xl bg-white p-8 shadow-md">
      <h1 class="text-4xl font-extrabold text-slate-800">
        Auditoriums
      </h1>

      <p class="mt-4 text-slate-600">
        This page can include auditorium locations, seating information, and
        directions for students.
      </p>

      <ul>
        <li>Auditorium 1 Block E Level 7</li>
        <li>Auditorium 2 Block B Level 6</li>
        <li>Auditorium 3 Block C</li>
        <li>Auditorium 4 Level 3</li>
        <li>Auditorium 5 Level 3</li>
        <li>Auditorium 6 Block C Level 3 </li>
        <li>Auditorium 7 Block A Level 3 </li>
      </ul>
    </div>
  </section>
</Layout>
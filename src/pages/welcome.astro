---
import Layout from "../layouts/Layout.astro";

import cat1 from "../assets/cat-with-laptop.png";
import cat2 from "../assets/cat-with-laptop.png";
---

<Layout title="Welcome">
  <section class="relative min-h-[calc(100vh-80px)] overflow-hidden bg-slate-50 px-6 py-12 md:px-12 lg:px-16">
    <!-- Text section -->
    <div class="mx-auto max-w-5xl pb-10 text-center md:pb-48">
      <p class="mb-4 font-semibold text-green-600">
        Welcome to APU
      </p>

      <h1 class="mx-auto max-w-4xl text-4xl font-extrabold leading-tight text-slate-800 sm:text-5xl lg:text-6xl">
        Congratulations on your enrollment in APU!
      </h1>

      <p class="mt-6 text-lg font-semibold text-slate-700">
        You might be wondering:
      </p>

      <ul class="mx-auto mt-5 grid max-w-4xl gap-4 text-left md:grid-cols-2">
        <li class="rounded-2xl border border-sky-100 bg-white px-5 py-4 font-medium text-slate-700 shadow-sm">
          Where is my class located?
        </li>

        <li class="rounded-2xl border border-sky-100 bg-white px-5 py-4 font-medium text-slate-700 shadow-sm">
          Where can I charge my devices?
        </li>

        <li class="rounded-2xl border border-sky-100 bg-white px-5 py-4 font-medium text-slate-700 shadow-sm">
          Where are the event announcements?
        </li>

        <li class="rounded-2xl border border-sky-100 bg-white px-5 py-4 font-medium text-slate-700 shadow-sm">
          Are there places near the campus?
        </li>
      </ul>

      <div class="mx-auto mt-8 max-w-3xl rounded-3xl bg-sky-100 p-6 shadow-sm">
        <p class="text-slate-700">
          We got you covered! Just click on the keywords shown at the header
          as your guidance.
        </p>

        <p class="mt-4 text-xl font-bold text-green-600">
          Have a wonderful university life!
        </p>
      </div>
    </div>

    <!-- Bottom images -->
    <div class="pointer-events-none mt-8 flex items-end justify-between gap-6 md:absolute md:bottom-6 md:left-0 md:right-0 md:mt-0 md:px-12 lg:px-20">
      <img
        src={cat1.src}
        alt="Cat with laptop"
        class="w-36 sm:w-44 md:w-56 lg:w-72"
      />

      <img
        src={cat2.src}
        alt="Cat with laptop"
        class="w-36 scale-x-[-1] sm:w-44 md:w-56 lg:w-72"
      />
    </div>
  </section>
</Layout>